<%- include("partials/header") %>

<div class="container mx-auto mt-12 px-4">
  <!-- HERO SECTION -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-4">Welcome to Rentease</h1>
    <p class="text-gray-600 mb-6">Find your dream rental property easily.</p>

    <a href="/properties" class="bg-blue-600 text-white px-6 py-3 rounded hover:bg-blue-700">
      Browse Properties
    </a>

    <% if (user && user.role === "owner") { %>
      <a href="/properties/add" class="bg-green-600 text-white px-6 py-3 rounded hover:bg-green-700 ml-4">
        Add Property
      </a>
    <% } %>
  </div>

  <!-- PROPERTIES SECTION -->
  <h2 class="text-2xl font-semibold mb-6">Latest Properties</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% properties.forEach((property) => { %>
      <div class="border rounded shadow p-4">
        <% if (property.image) { %>
          <img src="/uploads/<%= property.image %>" alt="<%= property.title %>" class="w-full h-48 object-cover mb-4 rounded">
        <% } else { %>
          <div class="w-full h-48 bg-gray-200 mb-4 flex items-center justify-center text-gray-500 rounded">
            No Image
          </div>
        <% } %>
        <h3 class="text-xl font-bold mb-2"><%= property.title %></h3>
        <p class="text-gray-600 mb-2"><%= property.location %></p>
        <p class="text-gray-800 font-semibold mb-2">$<%= property.price %> / month</p>
        <a href="/properties/<%= property._id %>" class="text-blue-600 hover:underline">View Details</a>
      </div>
    <% }) %>
  </div>
</div>

<%- include("partials/footer") %>