<%- include("../partials/header") %>

<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded shadow-lg">

  <h2 class="text-3xl font-bold mb-6 text-center">Add New Property</h2>

  <!-- Error / Success messages -->
  <% if (typeof error !== 'undefined') { %>
    <p class="bg-red-100 text-red-700 p-2 mb-4 rounded"><%= error %></p>
  <% } %>

  <% if (typeof success !== 'undefined') { %>
    <p class="bg-green-100 text-green-700 p-2 mb-4 rounded"><%= success %></p>
  <% } %>

  <form action="/api/properties/add" method="POST" enctype="multipart/form-data" class="space-y-4">

    <div>
      <label class="block text-gray-700 mb-1">Title</label>
      <input type="text" name="title" required class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
    </div>

    <div>
      <label class="block text-gray-700 mb-1">Description</label>
      <textarea name="description" required rows="4" class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
    </div>

    <div>
      <label class="block text-gray-700 mb-1">Price (₹)</label>
      <input type="number" name="price" required class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
    </div>

    <div>
      <label class="block text-gray-700 mb-1">Location</label>
      <input type="text" name="location" required class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
    </div>

    <!-- NEW FIELD -->
    <div>
      <label class="block text-gray-700 mb-1">Owner Contact Number</label>
      <input type="text" name="ownerContact" required class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
    </div>

    <div>
      <label class="block text-gray-700 mb-1">Property Image</label>
      <input type="file" name="image" class="border p-2 w-full rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
    </div>

    <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700 transition">
      Add Property
    </button>

  </form>

</div>

<%- include("../partials/footer") %>