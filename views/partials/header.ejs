<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rentease</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>

<body class="bg-gray-100">

<header class="bg-white shadow">
  <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">

    <h1 class="text-2xl font-bold text-gray-800">Rentease</h1>

    <nav class="space-x-4">

      <a href="/" class="text-gray-700 hover:text-blue-600 transition">Home</a>
      <a href="/properties" class="text-gray-700 hover:text-blue-600 transition">Properties</a>

      <% if(user){ %>
        <a href="/dashboard" class="text-gray-700 hover:text-blue-600 transition">Dashboard</a>

        <% if(user.role === "owner"){ %>
          <a href="/properties/add" class="text-gray-700 hover:text-blue-600 transition">Add Property</a>
        <% } %>

        <a href="/logout" class="text-red-600 hover:text-red-800 transition">Logout</a>

      <% } else { %>
        <a href="/login" class="text-gray-700 hover:text-blue-600 transition">Login</a>
        <a href="/register" class="text-gray-700 hover:text-blue-600 transition">Register</a>
      <% } %>

    </nav>
  </div>
</header>

<main class="max-w-7xl mx-auto p-4">